{
  "app-id": "com.nawakarit.pomodoro",
  "runtime": "org.freedesktop.Platform",

  "runtime-version": "23.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "Pomodoro",
  "finish-args": [
    "--share=network",
    "--filesystem=home",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri"
  ],
  "modules": [
    {
      "name": "Pomodoro",
      "buildsystem": "simple",
      "build-commands": [
        "install -D Pomodoro /app/bin/Pomodoro",
        "install -D com.nawakarit.pomodoro.desktop /app/share/applications/com.nawakarit.pomodoro.desktop",

        "install -D com.nawakarit.pomodoro.metainfo.xml /app/share/metainfo/com.nawakarit.pomodoro.metainfo.xml",

        "install -D icon-512.png /app/share/icons/hicolor/512x512/apps/com.nawakarit.pomodoro.png"


        
      ],
      "sources": [
        { "type": "file", "path": "../Pomodoro" },
        { "type": "file", "path": "com.nawakarit.pomodoro.desktop" },
        { "type": "file", "path": "com.nawakarit.pomodoro.metainfo.xml" },

        { "type": "file", "path": "icon-512.png" }
      ]
    }
  ]
}
