[Application]
name=com.nawakarit.pomodoro
runtime=org.freedesktop.Platform/x86_64/23.08
sdk=org.freedesktop.Sdk/x86_64/23.08
command=pomodoro

[Context]
shared=network;
sockets=x11;wayland;fallback-x11;
devices=dri;
filesystems=home;

[Extension com.nawakarit.pomodoro.Debug]
directory=lib/debug
autodelete=true
no-autodownload=true

[Build]
built-extensions=com.nawakarit.pomodoro.Debug;